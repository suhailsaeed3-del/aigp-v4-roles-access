# ============================================================================
# AI Transformation Portal — environment configuration (production handover)
# ----------------------------------------------------------------------------
# Copy this file to `.env` and fill in every value marked (REQUIRED).
# Values marked (build-time) must be set BEFORE `npm run build` / docker build,
# because Next.js inlines NEXT_PUBLIC_* variables into the client bundle.
# Nothing else in the code needs to change — only the values below.
# ============================================================================

# ---- Data layer ------------------------------------------------------------
# "local" = browser localStorage (static demo). "api" = Postgres via the API
# routes. Production MUST be "api".  (build-time)
NEXT_PUBLIC_DATA_MODE=api

# Postgres connection string.  (REQUIRED)
# Format: postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public
DATABASE_URL=postgresql://portal:portal@localhost:5432/transformation?schema=public

# ---- Sessions / security ---------------------------------------------------
# Secret used to sign the stateless HMAC session cookie (lib/security/session).
# Generate with:
#   openssl rand -hex 32
# (REQUIRED — min 32 chars in production)
SESSION_SECRET=
# Session lifetime in hours (default 12). SESSION_TTL_SECONDS overrides it.
SESSION_TTL_HOURS=12
# Optional cookie tuning (sensible defaults applied):
# SESSION_COOKIE_NAME=aigp_session
# SESSION_COOKIE_SECURE=true          # defaults to true in production
# SESSION_COOKIE_SAME_SITE=lax        # lax | strict | none
# Shared secret guarding writes to /api/state (demo-mode persistence only —
# production traffic should go through the enforced APIs). Set for any shared
# deployment.
STATE_API_TOKEN=

# ---- Server auth provider (RBAC security layer) -----------------------------
# Which identity provider backs /api/auth/login. "mock" is for local dev only
# and is disabled in production. Production must be uaepass or workspaceone.
AUTH_PROVIDER=mock                     # mock | uaepass | workspaceone
NEXT_PUBLIC_AUTH_PROVIDER=mock         # keep in sync with AUTH_PROVIDER (build-time)
# Comma-separated emails auto-provisioned as system_admin on first login.
# (REQUIRED for the first production sign-in)
BOOTSTRAP_ADMIN_EMAILS=
# Public base URL of the deployment, used for OIDC redirects (optional).
APP_BASE_URL=
# Dev-only identity used by the mock provider:
# MOCK_USER_EMAIL=admin@example.com
# MOCK_USER_NAME=

# ---- Workspace ONE / generic confidential-client OIDC -----------------------
# (REQUIRED when AUTH_PROVIDER=workspaceone; unused otherwise)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://YOUR_HOST/callback
OIDC_SCOPE=openid profile email
OIDC_CLIENT_AUTHENTICATION=client_secret_post   # or client_secret_basic

# ---- Rate limiting / AI review toggles ---------------------------------------
# Deployment-config placeholders read by lib/security/env.ts — enforce rate
# limiting at the edge/ingress. (optional)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
AI_REVIEW_ENABLED=true

# Seed sample portfolio items + launch plans into the database — for demo or
# staging databases ONLY. Leave unset in production: the portfolio starts
# empty (reference data + starter accounts only). (optional)
# SEED_DEMO_ITEMS=1

# ---- UAE PASS SSO (OpenID Connect) -----------------------------------------
# "mock" jumps straight into the app (demo). "live" uses the real IdP and
# requires the credentials below.  (build-time)
NEXT_PUBLIC_UAEPASS_MODE=live
UAEPASS_ENV=production                 # staging | production
UAEPASS_CLIENT_ID=                     # (REQUIRED for live)
UAEPASS_CLIENT_SECRET=                 # (REQUIRED for live)
UAEPASS_REDIRECT_URI=https://YOUR_HOST/api/auth/uaepass/callback   # (REQUIRED for live)
# Optional overrides (sensible defaults are applied per UAEPASS_ENV):
# UAEPASS_BASE_URL=https://id.uaepass.ae/idshub
# UAEPASS_SCOPE=urn:uae:digitalid:profile:general
# UAEPASS_ACR=urn:safelayer:tws:policies:authentication:level:low

# ---- Default role (fallback only; real role comes from the users table) ----
NEXT_PUBLIC_DEFAULT_ROLE=entity        # (build-time)

# ---- Internal AI reviewer (مراجعة ذكية) ------------------------------------
# Any OpenAI-compatible chat-completions endpoint. If unset/unreachable the
# app falls back to the built-in heuristic reviewer.
AI_API_BASE_URL=http://localhost:8000/v1
AI_API_KEY=
AI_MODEL=default

# ---- Sub-path hosting (only if served from /<path>, e.g. GitHub Pages) -----
# Leave unset when hosting at a domain root.  (build-time)
# NEXT_PUBLIC_BASE_PATH=/Transformation

# ---- Demo switches — MUST stay 0 in production -----------------------------
NEXT_PUBLIC_DEMO_MODE=0    # 1 = show the role-switcher tabs (demo/testing only)
NEXT_PUBLIC_DEMO_DATA=0    # 1 = seed the mock portfolio (presentation only)
